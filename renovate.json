{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "labels": ["dependencies"],
  "schedule": ["before 5am on monday"],
  "rebaseWhen": "conflicted",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "vite — ships in the bundle, so review manually (all update types).",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "vite",
        "vitest",
        "@tailwindcss/vite",
        "vite-plugin-{/,}**",
        "@vitejs/**",
        "@vitest/**"
      ],
      "groupName": "vite",
      "automerge": false
    },
    {
      "description": "typescript-toolchain — peer-coupled dev tooling; auto-merge on green (all types). Never ships (tsc --noEmit + lint only).",
      "matchManagers": ["npm"],
      "matchPackageNames": [
        "typescript",
        "eslint",
        "typescript-eslint",
        "globals",
        "@eslint/**",
        "eslint-plugin-**",
        "@typescript-eslint/**"
      ],
      "groupName": "typescript-toolchain",
      "automerge": true
    },
    {
      "description": "@types/* — type defs only, erased at build; auto-merge on green (all types).",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@types/**"],
      "groupName": "types",
      "automerge": true
    },
    {
      "description": "Other npm minor/patch — one grouped PR, auto-merge on green (low risk).",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor-and-patch",
      "automerge": true
    },
    {
      "description": "npm MAJORS — manual by default; individual PRs (runtime deps like react/dexie affect users).",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "npm major SAFE list — non-shipping dev tooling + type defs, fully CI-gated; auto-merge (a bad bump only turns CI red, never reaches users).",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "matchPackageNames": [
        "typescript",
        "eslint",
        "typescript-eslint",
        "globals",
        "jsdom",
        "prettier",
        "@types/**",
        "@eslint/**",
        "eslint-plugin-**",
        "@typescript-eslint/**",
        "@testing-library/**"
      ],
      "automerge": true
    },
    {
      "description": "GitHub Actions — any update auto-merges (the action runs inside the gating CI); minor/patch batched into one PR.",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "github-actions"
    },
    {
      "description": "Hold TypeScript on 6.x — TS 7 is the native-compiler rewrite (breaking major) and its toolchain lags it; revisit as a deliberate migration (was #19). Minors/patches still flow.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
