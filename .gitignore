# Inbox Clinic - Git Ignore File (TypeScript monorepo)

# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Vite / PWA dev artifacts
.vite/
dev-dist/

# Test & coverage
coverage/

# Playwright (Tier-3 E2E) — reports, traces, and downloaded browsers
test-results/
playwright-report/
blob-report/
.playwright/

# Environment & local config (the app holds no secrets — never commit local env)
.env
.env.local
.env.*.local
*.local

# Wrangler (Cloudflare Pages Functions) local secrets & state
.dev.vars
.dev.vars.*
.wrangler/

# OAuth tokens / credentials (should never exist; guard anyway)
token.json
credentials.json

# Editor / IDE — track shared VS Code config, ignore personal
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace

# Claude Code — ignore local settings and ephemeral plans
.claude/settings.local.json
.claude/plans/

# OS
.DS_Store
Thumbs.db
*~
*.swp
*.swo

# Logs
*.log
logs/
